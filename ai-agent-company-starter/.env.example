# Application
APP_NAME=AI Agent Company Platform
APP_VERSION=0.2.0
APP_ENV=local
DEBUG=true
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Paths
AGENTS_MANIFEST_PATH=agents/manifest.json
GLOBAL_RULES_PATH=docs/global-operating-rules.md
DATA_DIR=/tmp/agent_platform_data
DATABASE_URL=sqlite:////tmp/agent_platform_data/executions.db

# Access/Admin
ADMIN_ENABLED=true
ADMIN_WRITE_ENABLED=false
CORS_ORIGINS=*

# Execution/LLM
DEFAULT_EXECUTION_MODE=mock
LLM_PROVIDER=none
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
